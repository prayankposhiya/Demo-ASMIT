# CRM Backend - Environment Variables
# Copy this to .env and fill in your values

# ─── SERVER ────────────────────────────────────────────────
PORT=8000

# ─── MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=123456
DB_NAME=crm_db

# ─── ZITADEL (OIDC) ────────────────────────────────────────
# Issuer URL = your Zitadel instance domain (no trailing slash)
ZITADEL_ISSUER=https://demotask-8o6xcx.us1.zitadel.cloud

# Audience = the PROJECT ID (Zitadel puts project ID in "aud" claim)
ZITADEL_AUDIENCE=362714480683006278

# ─── CORS ──────────────────────────────────────────────────
# Frontend dev server origin
CORS_ORIGIN=http://localhost:5173

